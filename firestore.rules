rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Business profiles
    match /businesses/{businessId} {
      function isValidBusiness(data) {
        return data.keys().hasAll(['ownerId', 'name']) && 
               data.ownerId is string && 
               data.name is string && data.name.size() > 0 && data.name.size() < 100;
      }
      
      allow read: if true; // Public profiles
      allow create: if isSignedIn() && isOwner(request.resource.data.ownerId) && isValidBusiness(request.resource.data);
      allow update: if isOwner(resource.data.ownerId) && isValidBusiness(request.resource.data) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'description', 'logoUrl', 'website']);
    }

    // Fairs
    match /fairs/{fairId} {
      allow read: if true;
      allow write: if false; // Only admins (manual/backend) can create fairs for now

      // Finale leads (global, admin only)
      match /finale_leads/{finaleId} {
        allow read: if true;
        allow create: if true;
        // Progressive save: allow updating only the running catch-progress fields
        allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['shopIds', 'caughtCount', 'updatedAt']);
      }

      // Early signups (email dialog at game start)
      match /early_signups/{signupId} {
        allow read: if true;
        allow create: if true;
      }

      // Shop interests (auto-saved when user stops at a shop)
      match /shop_interests/{interestId} {
        allow read: if true;
        allow create: if true;
      }
      
      // Shops in a fair
      match /shops/{shopId} {
        function isValidShop(data) {
          return data.keys().hasAll(['fairId', 'businessId', 'giftName']) &&
                 data.fairId == fairId &&
                 data.businessId is string &&
                 data.giftName is string && data.giftName.size() > 0;
        }

        allow read: if true;
        allow create: if isSignedIn() && isValidShop(request.resource.data); // Anyone signed in as business can join fair
        allow update: if isSignedIn() && request.resource.data.businessId == resource.data.businessId && isValidShop(request.resource.data);

        // Leads in a shop
        match /leads/{leadId} {
          function isValidLead(data) {
            return data.keys().hasAll(['shopId', 'email', 'name']) &&
                   data.email is string && data.email.size() > 5 &&
                   data.name is string && data.name.size() > 1;
          }

          // Any signed-in user can read leads (admin gate is enforced in the app)
          allow read: if isSignedIn();
          allow create: if true; // Anyone can sign up for a gift
        }
      }
    }
  }
}
